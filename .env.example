# Bitkub
SECRET_KEY=your_secret_key
API_KEY=your_api_key

# Telegram
TELOXIDE_TOKEN=your_telegram_token
AUTHORIZED_USER_ID=your_chat_id

# Database
PGPASSWORD=your_db_password
DATABASE_URL="postgres://postgres:password@localhost:5432/dca_btc"

# App Info
APP_VERSION="1.0.0"

# Schedule
SCHEDULE_ENABLED=true
SCHEDULE_AMOUNT=100
# Examples:
# SCHEDULE_CRON="0 0 8 * * *"   # Daily at 08:00
# SCHEDULE_CRON="0 */1 * * * *"  # Every minute
# SCHEDULE_CRON="0 */5 * * * *"  # Every 5 minutes
# SCHEDULE_CRON="0 */10 * * * *" # Every 10 minutes
SCHEDULE_CRON="0 0 8 * * *"
